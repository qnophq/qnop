# Local development configuration for qnop. Copy to `.env` (git-ignored).
# SPDX-License-Identifier: AGPL-3.0-only
#
# Every variable is QNOP_-prefixed — a single namespace for the qnop application
# and its local infrastructure. docker-compose maps these onto the names the
# official images require (POSTGRES_* / MINIO_*); the server reads the same
# QNOP_DB_* directly (ADR-0020). LOCAL DEV defaults only — production secrets
# come from the environment / a secret manager, never a committed file.

# --- Database (PostgreSQL) ---
QNOP_DB_NAME=qnop
QNOP_DB_USERNAME=qnop
QNOP_DB_PASSWORD=qnop
QNOP_DB_PORT=5432
# QNOP_DB_HOST=localhost   # only needed when the server runs apart from the DB

# --- Object storage (S3 API / MinIO) ---
QNOP_S3_ACCESS_KEY=qnop
QNOP_S3_SECRET_KEY=qnop_secret
QNOP_S3_PORT=9000
QNOP_S3_CONSOLE_PORT=9001
QNOP_S3_BUCKET=qnop-documents

# --- Running the server ---
# docker-compose loads this file automatically. For `./gradlew :qnop-app:bootRun`
# export these into your shell first:  set -a; source .env; set +a
# Production may instead set the standard SPRING_DATASOURCE_* keys, which override
# the QNOP_DB_*-derived defaults.
