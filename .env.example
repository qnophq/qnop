# Local development configuration for qnop. Copy to `.env` (git-ignored).
# SPDX-License-Identifier: AGPL-3.0-only
#
# These are LOCAL DEV defaults only. Production secrets come from the
# environment / a secret manager, never from a committed file.

# --- PostgreSQL ---
POSTGRES_USER=qnop
POSTGRES_PASSWORD=qnop
POSTGRES_DB=qnop
POSTGRES_PORT=5432

# --- Object storage (S3 API / MinIO) ---
S3_ACCESS_KEY=qnop
S3_SECRET_KEY=qnop_secret
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_BUCKET=qnop-documents

# --- Application (qnop server) ---
# The server's datasource reads the SAME POSTGRES_* variables above (ADR-0020),
# so this one file configures both docker-compose and the app. docker-compose
# loads .env automatically; for `./gradlew :qnop-app:bootRun` export them into
# your shell first (e.g. `set -a; source .env; set +a`). When the DB runs
# elsewhere, also set POSTGRES_HOST (defaults to localhost).
# POSTGRES_HOST=localhost
# Production may instead set the standard SPRING_DATASOURCE_URL / _USERNAME /
# _PASSWORD, which override the POSTGRES_*-derived defaults.
