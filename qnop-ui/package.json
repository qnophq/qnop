{
  "name": "qnop-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "generate:api": "openapi-generator-cli generate",
    "dev": "pnpm generate:api && vite",
    "build": "pnpm generate:api && tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm generate:api && tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.3",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/outfit": "5.2.8",
    "@mui/material": "9.1.2",
    "@mui/x-date-pickers": "^9.7.0",
    "@tanstack/react-query": "5.101.2",
    "@uiw/react-codemirror": "4.25.10",
    "axios": "1.18.1",
    "date-fns": "^4.4.0",
    "lucide-react": "1.22.0",
    "pdfjs-dist": "^6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-easy-crop": "6.0.2",
    "react-image-crop": "11.1.2",
    "react-router-dom": "7.18.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@openapitools/openapi-generator-cli": "2.39.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.2",
    "vitest": "4.1.9",
    "vitest-axe": "^0.1.0"
  }
}
