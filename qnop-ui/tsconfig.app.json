{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    // `node` is needed only so tsc resolves the generated client's
    // `import { URL } from 'url'`; at runtime a Vite alias maps it to a shim.
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path alias (mirrors the Vite resolve.alias) */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting — unused-symbol detection is delegated to ESLint
       (@typescript-eslint/no-unused-vars), which ignores the generated client;
       tsc must tolerate the generator's unused cookie params. */
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
